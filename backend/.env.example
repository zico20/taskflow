# --- App ---
PROJECT_NAME=TaskFlow
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api

# --- Database ---
# Local dev (no Docker): SQLite file.
DATABASE_URL=sqlite+aiosqlite:///./taskflow.db
# Docker / production (Postgres). Uncomment and set when using docker-compose:
# DATABASE_URL=postgresql+asyncpg://taskflow:taskflow@db:5432/taskflow

# --- Security / JWT ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# --- Cookie ---
COOKIE_NAME=taskflow_access_token
COOKIE_SECURE=false          # set true in production (HTTPS)
COOKIE_SAMESITE=lax          # lax | strict | none
# COOKIE_DOMAIN=

# --- CORS (comma-separated origins for the frontend) ---
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Rate limiting ---
AUTH_RATE_LIMIT=10/minute
